{
  "$schema": "https://docs.xentara.io/xentara/schema-xentara-model.json",
  "children": [
    "#CoE.Bus:EtherCAT Terminal",
    {
      "@Group": {
        "name": "Connection",
        "UUID": "322a00a4-8dd2-4f94-8787-bdba2f01df6f",
        "children": [
          {
            "@DataPoint": {
              "name": "DO1-White",
              "UUID": "5d11b12f-b08f-4add-9c3e-443a70946339",
              "io": "EtherCAT Terminal.WAGO Series 750 Bus Coupler.Channel 1, Data 1"
            }
          },
          {
            "@DataPoint": {
              "name": "DO2-Blue",
              "UUID": "4c533f56-7f85-4c56-9729-f826c8054eb9",
              "io": "EtherCAT Terminal.WAGO Series 750 Bus Coupler.Channel 2, Data 1"
            }
          },
          {
            "@DataPoint": {
              "name": "DO3-Head",
              "UUID": "0d763458-e1ce-4d01-84b7-8c6c49e9bd5b",
              "io": "EtherCAT Terminal.WAGO Series 750 Bus Coupler.Channel 3, Data 1"
            }
          }
        ]
      }
    },
    {
      "@Skill.MQTT.Client": {
        "name": "Docker-MQTT",
        "UUID": "1ce45fa0-7501-404c-b149-2f4fedf17ba8",
        "brokerAddress": "192.168.2.124",
        "TLS": {
          "enabled": false
        },
        "MQTTVersion": "5",
        "keepaliveInterval": "60s",
        "children": [
          {
            "@Skill.MQTT.Command": {
              "name": "Command",
              "UUID": "fe076a7e-a169-4d6c-a6d7-d4b41ad466b8",
              "topic": "inference/yolov5m-results",
              "payload": [
                {
                  "@DataPoint": {
                    "jsonPath": "$.detections",
                    "dataPoint": "Registers.MQTT-Payload",
                    "asJSONText": true
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "@Group": {
        "name": "Registers",
        "UUID": "637f23d5-a69e-4433-b44d-74e8d628dcc7",
        "children": [
          {
            "@Skill.SignalFlow.Register": {
              "name": "MQTT-Payload",
              "UUID": "1ceac447-7894-4169-a904-14b6e0c1bdba",
              "defaultValue": [
                "string",
                ""
              ]
            }
          }
        ]
      }
    },
    {
      "@Group": {
        "name": "Control",
        "UUID": "7af7b8a4-35ea-4af2-90b7-02ab374c6ab9",
        "children": [
          {
            "@Skill.CPP.Control": {
              "name": "MQTTPayloadControl",
              "UUID": "de68b55e-ce6f-4264-8394-bf34953624bb",
              "controlPath": "MQTTPayloadControl.so",
              "parameters": {
                "Payload": "Registers.MQTT-Payload",
                "White": "Connection.DO1-White",
                "Blue": "Connection.DO2-Blue",
                "Head": "Connection.DO3-Head"
              }
            }
          }
        ]
      }
    },
    {
      "@Track": {
        "name": "Track EtherCAT Control",
        "UUID": "324f4d0e-ba71-4e48-be9c-b85c8f05f84a",
        "children": [
          {
            "@Timer": {
              "name": "Timer1ms",
              "UUID": "8663d201-7c2f-4999-8fbd-17cfa5a46570",
              "period": "1ms"
            }
          },
          {
            "@Pipeline": {
              "name": "Pipeline",
              "UUID": "d3319792-7c50-42a8-aaff-336fb3671485",
              "triggers": [
                "Track EtherCAT Control.Timer1ms.expired"
              ],
              "checkpoints": [
                {},
                {}
              ],
              "segments": [
                {
                  "start": 0,
                  "end": 1,
                  "tasks": [
                    {
                      "function": "Control.MQTTPayloadControl.step"
                    },
                    {
                      "function": "EtherCAT Terminal.loop"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "@Track": {
        "name": "Track MQTT Reconnect",
        "UUID": "6e8b4f8f-5c9f-4a34-a7e6-f828e07a8c52",
        "children": [
          {
            "@Timer": {
              "name": "Timer5s",
              "UUID": "f6f66f28-6175-4fb7-8029-ebb04516d8af",
              "period": "5s"
            }
          },
          {
            "@Pipeline": {
              "name": "PipelineReconnect",
              "UUID": "9e3f50d5-8b50-4f71-bdca-0313a8318e43",
              "triggers": [
                "Track MQTT Reconnect.Timer5s.expired"
              ],
              "checkpoints": [
                {},
                {}
              ],
              "segments": [
                {
                  "start": 0,
                  "end": 1,
                  "tasks": [
                    {
                      "function": "Docker-MQTT.reconnect"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
